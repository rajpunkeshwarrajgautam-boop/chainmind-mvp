ENVIRONMENT=development

# --- No Docker: use SQLite + eager Celery (no Redis worker required). Uncomment:
# DATABASE_URL=sqlite:///./chainmind-local.db
# CELERY_TASK_ALWAYS_EAGER=true

# Full local stack (Postgres + Redis) or Docker Compose:
DATABASE_URL=postgresql+psycopg2://chainmind:chainmind@localhost:5432/chainmind
# Render (production): set DATABASE_URL in the service dashboard when using root render.yaml (sync: false placeholder).
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
JWT_SECRET=replace-with-long-random-secret-minimum-32-characters
# Local dev + production web (Vercel). On Render/hosted API, set explicitly, e.g.:
# CORS_ORIGINS=https://chainmind-mvp-web.vercel.app,http://localhost:3000
# Optional: allow all Vercel preview deployments from this team/project:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://chainmind-mvp-web.vercel.app

# Next.js dev proxy to this API (see web/next.config.mjs)
# API_ORIGIN=http://127.0.0.1:8000
TRUSTED_HOSTS=localhost,127.0.0.1
CHAINMIND_API_KEY=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
CELERY_TASK_ALWAYS_EAGER=false

# OIDC SSO (Okta / Azure AD / Auth0)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://localhost:8000/api/v1/auth/oidc/callback
OIDC_SCOPE=openid email profile
OIDC_ROLE_CLAIM=groups
OIDC_ADMIN_GROUPS=chainmind-admins
OIDC_JIT_PROVISION=false

# Optional S3 for uploads
AWS_REGION=
AWS_S3_BUCKET=
AWS_KMS_KEY_ID=

# Stripe go-live
STRIPE_CUSTOMER_PORTAL_RETURN_URL=
